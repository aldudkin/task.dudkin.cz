%% Loki on ECS Fargate — security-group boundaries + data flow
%% Entry: ALB (:80 → 301 redirect to :443 HTTPS, ACM cert for task.dudkin.cz)
%%        /loki/* → nginx gateway (:8080) → components (:3100); default → Grafana (:3000)
%% Source of truth: config/loki-config.yml, loki/sg.tf, loki/alb.tf, loki/grafana.tf
%% Ports: 3100 = client-facing + internal HTTP | 9095 = inter-component gRPC | 7946 = memberlist gossip (TCP+UDP)
flowchart TB
    %% ===== Outside AWS / public =====
    subgraph NET["Internet"]
        AG["Log agents<br/>Fluent Bit · Grafana Alloy"]
        DEV["Developer browser<br/>(Grafana UI)"]
    end

    %% ===== SG: loki-alb =====
    subgraph SGALB["SG: loki-alb"]
        ALB["Application Load Balancer<br/>:80 → 301 redirect to :443<br/>:443 HTTPS (ACM, task.dudkin.cz)"]
    end

    %% ===== SG: grafana =====
    subgraph SGGRAF["SG: grafana"]
        GRAF["Grafana task<br/>:3000 (LogQL UI)"]
    end

    %% ===== SG: loki-gateway =====
    subgraph SGGW["SG: loki-gateway"]
        GW["nginx gateway task<br/>:8080 — routes read vs write"]
    end

    %% ===== SG: loki-internal (the mesh) =====
    subgraph SGINT["SG: loki-internal — self-rule covers :3100 / :9095 / :7946 (TCP+UDP)"]
        DIST["distributor :3100"]
        ING["ingester :9095"]
        QF["query-frontend :3100"]
        QS["query-scheduler :9095"]
        QR["querier"]
        IG["index-gateway :9095"]
        COMP["compactor :3100"]
    end

    S3[("Amazon S3<br/>chunks + TSDB index")]

    %% ----- entry: agents + dev -----
    AG -->|"POST /loki/api/v1/push (:80 or :443)"| ALB
    DEV -->|"HTTPS :443"| ALB

    %% ----- ALB routing rules -----
    ALB -->|"/loki/* → :8080"| GW
    ALB -->|"default → :3000"| GRAF

    %% ----- Grafana reads query-frontend DIRECTLY (not via gateway) -----
    GRAF -->|"read :3100 (datasource url)"| QF

    %% ----- gateway -> components -----
    GW -->|"write :3100"| DIST
    GW -->|"read :3100"| QF

    %% ----- internal mesh (self-rule, already covered) -----
    DIST -->|"gRPC :9095"| ING
    QF -->|"gRPC :9095"| QS
    QR -->|"pull :9095"| QS
    QR -->|"recent :9095"| ING
    QR -->|"index :9095"| IG

    %% ----- storage -----
    ING -->|"flush chunks+index"| S3
    QR -->|"old chunks"| S3
    IG -->|"read index"| S3
    COMP -->|"compact + retention"| S3

    classDef nw fill:#fff4e5,stroke:#e8920c;
    classDef s3 fill:#e8f0fe,stroke:#4285f4;
    class AG,DEV nw;
    class S3 s3;
